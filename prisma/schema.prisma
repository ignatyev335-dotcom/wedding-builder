generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum AuthProvider {
  GOOGLE
  TELEGRAM
  VK
  YANDEX
  EMAIL
  ANONYMOUS
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  VIP
}

enum MediaAssetType {
  ICON
  STICKER
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ThemeCode {
  MINIMAL
  BOHO
  CLASSIC
  MODERN
  ROMANTIC
  BOTANICAL
  EDITORIAL
}

enum ModuleType {
  HERO
  STORY
  RSVP
  DRESS_CODE
  TIMELINE
  TRANSFER
  MAP
  MUSIC
  GALLERY
  COUNTDOWN
  FAQ
}

enum GuestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TransportPreference {
  TRANSFER
  OWN_CAR
  SELF
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
}

enum PremiumFeature {
  REMOVE_BRANDING
  PREMIUM_THEMES
  RSVP
  TELEGRAM_NOTIFICATIONS
  PERSONAL_LINKS
  PREMIUM_MUSIC
  GALLERY
}

model User {
  id               String           @id @default(cuid())
  telegramId       String?          @unique
  telegramChatId   String?          @unique
  email            String?          @unique
  emailVerified    DateTime?
  phone            String?          @unique
  image            String?
  name             String?
  provider         AuthProvider     @default(ANONYMOUS)
  role             UserRole         @default(USER)
  subscriptionPlan SubscriptionPlan @default(FREE)
  passwordHash     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  weddingSites     WeddingSite[]
  orders           Order[]
  accounts         Account[]
  sessions         Session[]

  @@index([createdAt])
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
  @@index([phone, expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model WeddingSite {
  id                String       @id @default(cuid())
  userId            String
  slug              String       @unique
  theme             ThemeCode    @default(MINIMAL)
  templateStyle     String       @default("MINIMAL")
  status            SiteStatus   @default(DRAFT)
  musicTrackId      String?
  designThemeId     String?
  decorativeAssetId String?
  audioUrl          String?
  heroImageDesktop  String?
  heroImageMobile   String?
  giftPaymentLink   String?
  giftQrCode        String?
  pinCode           String?
  defaultLanguage   String       @default("RU")
  isPremium         Boolean      @default(false)
  removeBranding    Boolean      @default(false)
  rsvpEnabled       Boolean      @default(false)
  telegramAlerts    Boolean      @default(false)
  personalLinks     Boolean      @default(false)
  premiumMusic      Boolean      @default(false)
  galleryEnabled    Boolean      @default(false)
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  data              WeddingData?
  modules           SiteModule[]
  guests            Guest[]
  orders            Order[]
  crewTimings       CrewTiming[]
  musicTrack        AudioTrack?  @relation(fields: [musicTrackId], references: [id], onDelete: SetNull)
  designTheme       DesignTheme? @relation(fields: [designThemeId], references: [id], onDelete: SetNull)
  decorativeAsset   MediaAsset?  @relation(fields: [decorativeAssetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt])
  @@index([designThemeId])
  @@index([decorativeAssetId])
}

model PlatformContent {
  id                String   @id @default("global")
  greetingEnabled   Boolean  @default(true)
  timelineEnabled   Boolean  @default(true)
  dressCodeEnabled  Boolean  @default(true)
  mapEnabled        Boolean  @default(true)
  rsvpEnabled       Boolean  @default(true)
  primaryButtonText String   @default("Отправить ответ")
  footerText        String   @default("Создано на Vowly")
  errorText         String   @default("Что-то пошло не так. Попробуйте ещё раз.")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model MediaAsset {
  id        String         @id @default(cuid())
  name      String
  type      MediaAssetType
  url       String         @db.Text
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  sites     WeddingSite[]

  @@index([type, isActive])
  @@index([createdAt])
}

model DesignTheme {
  id              String        @id @default(cuid())
  name            String        @unique
  backgroundColor String
  primaryColor    String
  textColor       String
  fontFamily      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sites           WeddingSite[]

  @@index([createdAt])
}

model AudioTrack {
  id        String        @id @default(cuid())
  title     String
  artist    String
  fileUrl   String        @db.Text
  isActive  Boolean       @default(true)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sites     WeddingSite[]

  @@index([isActive, sortOrder])
}

model InvitationTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  category    String   @default("GENERAL")
  value       String   @db.Text
  isSecret    Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model WeddingData {
  id                  String      @id @default(cuid())
  weddingSiteId       String      @unique
  partnerOneName      String
  partnerTwoName      String
  weddingDate         DateTime
  ceremonyTime        String?
  venueName           String?
  venueAddress        String?
  mapLatitude         Float?
  mapLongitude        Float?
  welcomeText         String?
  dressCodeText       String?
  colorPalette        String?
  dressMoodboard      String?
  faqItems            String?
  coordinatorName     String?
  coordinatorRole     String?
  coordinatorPhoto    String?
  coordinatorTelegram String?
  coordinatorWhatsapp String?
  coordinatorPhone    String?
  coordinatorMapLink  String?
  photoMask           String?     @default("RECTANGLE")
  customQuestions     String?
  timeline            String?
  transfer            String?
  customContent       String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  weddingSite         WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)
}

model CrewTiming {
  id            String      @id @default(cuid())
  weddingSiteId String
  time          String
  description   String
  contactPerson String
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  weddingSite   WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@index([weddingSiteId, sortOrder])
}

model SiteModule {
  id            String      @id @default(cuid())
  weddingSiteId String
  type          ModuleType
  isEnabled     Boolean     @default(true)
  sortOrder     Int
  settings      String?
  weddingSite   WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@unique([weddingSiteId, type])
  @@unique([weddingSiteId, sortOrder])
  @@index([weddingSiteId, isEnabled])
}

model Guest {
  id                    String               @id @default(cuid())
  siteId                String               @map("weddingSiteId")
  customSlug            String?
  name                  String               @map("guestName")
  isCouple              Boolean              @default(false)
  partnerName           String?
  attendanceChoice      String?
  phone                 String
  status                GuestStatus          @default(PENDING) @map("attendance")
  magicToken            String               @unique
  alcoholPreferences    String               @default("[]")
  needsTransport        Boolean              @default(false)
  transportPreference   TransportPreference?
  dietaryRestrictions   String?
  foodPreference        String?
  partnerFoodPreference String?
  allergies             String?
  partnerAllergies      String?
  tags                  String               @default("[]")
  customAnswers         String               @default("{}")
  hasPlusOne            Boolean              @default(false)
  plusOneName           String?
  musicRequest          String?
  message               String?
  respondedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  weddingSite           WeddingSite          @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, customSlug])
  @@index([siteId, status])
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  weddingSiteId     String
  providerPaymentId String?     @unique
  idempotencyKey    String      @unique
  status            OrderStatus @default(PENDING)
  amountKopecks     Int
  currency          String      @default("RUB")
  features          String      @default("[]")
  paidAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  weddingSite       WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([weddingSiteId, status])
}
