generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum AuthProvider {
  TELEGRAM
  VK
  YANDEX
  EMAIL
  ANONYMOUS
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ThemeCode {
  MINIMAL
  BOHO
  CLASSIC
  MODERN
}

enum ModuleType {
  HERO
  STORY
  RSVP
  DRESS_CODE
  TIMELINE
  TRANSFER
  MAP
  MUSIC
  GALLERY
}

enum AttendanceStatus {
  PENDING
  ATTENDING
  NOT_ATTENDING
  MAYBE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
}

enum PremiumFeature {
  REMOVE_BRANDING
  PREMIUM_THEMES
  RSVP
  TELEGRAM_NOTIFICATIONS
  PERSONAL_LINKS
  PREMIUM_MUSIC
  GALLERY
}

model User {
  id          String       @id @default(cuid())
  telegramId  String?      @unique
  telegramChatId String?   @unique
  email       String?      @unique
  name        String?
  provider    AuthProvider @default(ANONYMOUS)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  weddingSites WeddingSite[]
  orders      Order[]

  @@index([createdAt])
}

model WeddingSite {
  id             String       @id @default(cuid())
  userId         String
  slug           String       @unique
  theme          ThemeCode    @default(MINIMAL)
  status         SiteStatus   @default(DRAFT)
  musicTrackId   String?
  isPremium      Boolean      @default(false)
  removeBranding Boolean      @default(false)
  rsvpEnabled    Boolean      @default(false)
  telegramAlerts Boolean      @default(false)
  personalLinks  Boolean      @default(false)
  premiumMusic   Boolean      @default(false)
  galleryEnabled Boolean      @default(false)
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  data           WeddingData?
  modules        SiteModule[]
  guests         Guest[]
  orders         Order[]

  @@index([userId])
  @@index([status, createdAt])
}

model WeddingData {
  id             String      @id @default(cuid())
  weddingSiteId  String      @unique
  partnerOneName String
  partnerTwoName String
  weddingDate    DateTime
  ceremonyTime   String?
  venueName      String?
  venueAddress   String?
  mapLatitude    Float?
  mapLongitude   Float?
  welcomeText    String?
  dressCodeText  String?
  colorPalette   String?
  timeline       String?
  transfer       String?
  customContent  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  weddingSite    WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)
}

model SiteModule {
  id            String      @id @default(cuid())
  weddingSiteId String
  type          ModuleType
  isEnabled     Boolean     @default(true)
  sortOrder     Int
  settings      String?
  weddingSite   WeddingSite @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@unique([weddingSiteId, type])
  @@unique([weddingSiteId, sortOrder])
  @@index([weddingSiteId, isEnabled])
}

model Guest {
  id                  String           @id @default(cuid())
  weddingSiteId       String
  customSlug          String?
  guestName           String
  attendance          AttendanceStatus @default(PENDING)
  alcoholPreferences  String           @default("[]")
  needsTransport      Boolean          @default(false)
  dietaryRestrictions String?
  plusOneName         String?
  message             String?
  respondedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  weddingSite         WeddingSite      @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@unique([weddingSiteId, customSlug])
  @@index([weddingSiteId, attendance])
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  weddingSiteId     String
  providerPaymentId String?       @unique
  idempotencyKey    String        @unique
  status            OrderStatus   @default(PENDING)
  amountKopecks     Int
  currency          String        @default("RUB")
  features          String        @default("[]")
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  weddingSite       WeddingSite   @relation(fields: [weddingSiteId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([weddingSiteId, status])
}
