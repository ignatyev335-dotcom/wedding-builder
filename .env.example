# PostgreSQL connection strings from Vercel Postgres / Neon.
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Use a long random value (at least 32 characters) in production.
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_YANDEX_ID=""
AUTH_YANDEX_SECRET=""
# Public application URL, for example https://vowly.ru
AUTH_URL=""
RESEND_API_KEY=""
EMAIL_FROM="Vowly <hello@example.com>"

# The first login with these credentials creates or promotes the superadmin.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# For local testing only. Never enable this in production.
AUTH_SHOW_OTP="false"

# Optional. Enables official Yandex address suggestions and coordinates.
YANDEX_GEOCODER_API_KEY=""

# Sends RSVP notifications to the Telegram chat connected to the project.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# Apple Wallet passes must be signed by a Pass Type ID certificate.
# The private signer must accept JSON and return application/vnd.apple.pkpass.
APPLE_WALLET_SIGNER_URL=""
APPLE_WALLET_SIGNER_TOKEN=""
